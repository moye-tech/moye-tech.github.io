.dr-chart-lbl{font-size:9px;color:var(--t2);margin-bottom:5px;font-family:var(--fm)}

/* ═══ STATUS BAR ═════════════════════════════════════════════════ */
#statusbar{
  position:fixed;bottom:0;left:0;right:0;z-index:300;height:var(--bot);
  background:rgba(4,8,16,.98);border-top:1px solid var(--b);
  display:flex;align-items:center;gap:14px;padding:0 12px;
  font-family:var(--fm);font-size:9.5px;color:var(--t2);
}
.sbi{display:flex;align-items:center;gap:4px;white-space:nowrap}
.sg{color:var(--green)}.sb{color:var(--blue)}.sa{color:var(--amber)}.sr{color:var(--red)}
#tkwrap{margin-left:auto;overflow:hidden;max-width:480px;white-space:nowrap}
#tkinner{display:inline-block;animation:tk 30s linear infinite}
@keyframes tk{0%{transform:translateX(100%)}100%{transform:translateX(-100%)}}

/* ═══ NOTIFICATIONS ══════════════════════════════════════════════ */
#notifs{position:fixed;top:calc(var(--top)+8px);right:14px;z-index:500;display:flex;flex-direction:column;gap:5px;pointer-events:none}
.ntf{padding:8px 12px;border-radius:var(--r);border:1px solid;font-size:10.5px;max-width:280px;animation:ni .2s ease,no .3s ease 4s forwards;backdrop-filter:blur(10px)}
.ni{background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.35);color:var(--blue)}
.nw{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.35);color:var(--amber)}
.nl{background:rgba(244,63,94,.1);border-color:rgba(244,63,94,.35);color:var(--red)}
.ns{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.35);color:var(--green)}
@keyframes ni{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:none}}
@keyframes no{to{opacity:0;transform:translateX(16px)}}

/* ═══ LOADING ════════════════════════════════════════════════════ */
#loader{
