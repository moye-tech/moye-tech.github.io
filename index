const Cache = {
  set(key, data, ttlMin=30) {
    try { sessionStorage.setItem(key, JSON.stringify({ data, expires: Date.now()+ttlMin*60000 })); } catch(e){}
  },
  get(key) {
    try {
      const item = JSON.parse(sessionStorage.getItem(key)||'null');
      if(item && item.expires > Date.now()) return item.data;
    } catch(e){}
    return null;
  }
};

/* ═══════════════════════════════════════════════════════════
   UTILS
   ═══════════════════════════════════════════════════════════ */
function dateMinusDays(d) {
  const dt = new Date(Date.now() - d*86400000);
  return dt.toISOString().slice(0,10);
}
function timeAgo(dateStr) {
  if(!dateStr) return '';
  const d = new Date(dateStr), now = new Date();
  const diff = (now-d)/1000;
  if(diff<60) return '刚刚';
  if(diff<3600) return Math.floor(diff/60)+'分钟前';
  if(diff<86400) return Math.floor(diff/3600)+'小时前';
  return Math.floor(diff/86400)+'天前';
}
function escHtml(s) {
  if(!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtNum(n) {
  if(n >= 1000) return (n/1000).toFixed(1)+'k';
  return String(n||0);
}
function langClass(lang) {
  const m = { Python:'py', TypeScript:'ts', JavaScript:'js', Rust:'rs', Go:'go', 'C++':'xx', Java:'xx', Ruby:'xx', PHP:'xx', Swift:'xx' };
  return m[lang] || 'xx';
}
function stripHtml(html) {
  if(!html) return '';
  return html.replace(/<[^>]+>/g,'').replace(/&nbsp;/g,' ').replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&quot;/g,'"').replace(/&#\d+;/g,'').trim();
}

/* ═══════════════════════��═══════════════════════════════════
   FETCH — GITHUB API (real data, verified)
   ═══════════════════════════════════════════════════════════ */
async function fetchGithub(period, topic) {
  const key = `gh-${period}-${topic}`;
  const cached = Cache.get(key);
  if(cached) return cached;

  const days = CFG.github.dateOffsets[period];
  const topicQuery = CFG.github.topics[topic] || CFG.github.topics.all;
  const q = `${topicQuery} created:>${dateMinusDays(days)}&sort=stars&order=desc&per_page=${CFG.github.perPage}`;
  const url = `${CFG.github.api}?q=${encodeURIComponent(q)}&per_page=${CFG.github.perPage}`;

  const t0 = Date.now();
  const res = await fetch(url, { headers: CFG.github.headers });

  document.getElementById('sb-lat').textContent = (Date.now()-t0)+'ms';
  document.getElementById('sb-gh').textContent = res.ok ? 'OK' : `${res.status}`;
  document.getElementById('sb-gh').style.color = res.ok ? 'var(--green)' : 'var(--red)';

  if(res.status === 403) {
    const reset = res.headers.get('X-RateLimit-Reset');
    const resetTime = reset ? new Date(reset*1000).toLocaleTimeString('zh-CN') : '1小时后';
    throw new Error(`GitHub API 速率限制，将在 ${resetTime} 重置 (60请求/小时)`);
  }
  if(!res.ok) throw new Error(`GitHub API 错误: ${res.status}`);

  const data = await res.json();
  Cache.set(key, data.items, 20);
  return data.items;
}

/* ═══════════════════════════════════════════════════════════
   FETCH — RSS NEWS (real data via multiple proxies)
   ═══════════════════════════════════════════════════════════ */
async function fetchRSSWithFallback(feed) {
  const cacheKey = `rss-${feed.id}`;
  const cached = Cache.get(cacheKey);
  if(cached) return cached.map(item=>({...item, _feed:feed}));

  // Try multiple proxies in order
  for(let i = 0; i < CFG.rss.proxies.length; i++) {
    try {
      const proxy = CFG.rss.proxies[i];
      const proxyUrl = proxy.url(feed.url);
      const res = await fetch(proxyUrl, { signal: AbortSignal.timeout(8000) });
      
      if(!res.ok) continue;
      
      const data = await res.json();
      
      // Parse based on proxy type
      let items = [];
      if(proxy.name === 'rss2json') {
        if(data.status !== 'ok') continue;
        items = data.items || [];
      } else if(proxy.name === 'allorigins') {
        if(!data.contents) continue;
        // Parse RSS XML from allorigins
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(data.contents, 'text/xml');
        const itemElements = xmlDoc.querySelectorAll('item');
        items = Array.from(itemElements).map(item => ({
          title: item.querySelector('title')?.textContent || '',
          description: item.querySelector('description')?.textContent || '',
          link: item.querySelector('link')?.textContent || '',
          pubDate: item.querySelector('pubDate')?.textContent || '',
          author: item.querySelector('author')?.textContent || '',
        }));
      }
      
      if(items.length > 0) {
        Cache.set(cacheKey, items, 30);
        return items.map(item=>({...item, _feed:feed}));
      }
    } catch(e) {
      console.warn(`Proxy ${CFG.rss.proxies[i].name} failed for ${feed.name}:`, e.message);
      continue;
    }
  }
  
  throw new Error(`所有代理均失败: ${feed.name}`);
}

async function fetchAllNews() {
  const results = await Promise.allSettled(CFG.rss.feeds.map(feed => fetchRSSWithFallback(feed)));
  const allItems = [];
  let okCount = 0;

  results.forEach((r, i) => {
    if(r.status === 'fulfilled') {
      allItems.push(...r.value);
      okCount++;
      S.loadedSources.add(CFG.rss.feeds[i].id);
    } else {
      console.warn(`Feed ${CFG.rss.feeds[i].name} failed:`, r.reason?.message);
    }
  });

  // Sort by date descending
  allItems.sort((a,b)=>{
    const da = new Date(a.pubDate||a.published||0);
    const db = new Date(b.pubDate||b.published||0);
    return db-da;
  });

  document.getElementById('sb-rss').textContent = `${okCount}/${CFG.rss.feeds.length} feeds`;
  document.getElementById('sb-rss').style.color = okCount>0 ? 'var(--green)' : 'var(--red)';
  return allItems;
}

