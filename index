  if(nb) nb.classList.add('active');
  document.querySelectorAll('.vtab').forEach(t=>t.classList.remove('active'));
  const vt = document.querySelector(`.vtab[data-view="${view}"]`);
  if(vt) vt.classList.add('active');
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  const viewEl = document.getElementById(`view-${view}`);
  if(viewEl) viewEl.classList.add('active');
  closeDrawer();
}

function setGhPeriod(period, el) {
  S.ghPeriod = period;
  document.querySelectorAll('#period-tabs .ptab').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  loadGithub();
}

function setGhTopic(topic, el) {
  S.ghTopic = topic;
  document.querySelectorAll('#topic-pills .tpill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  loadGithub();
}

/* ═══════════════════════════════════════════════════════════
   NOTIFICATIONS
   ═══════════════════════════════════════════════════════════ */
function notify(msg, cls='ni') {
  const c = document.getElementById('notifs');
  const el = document.createElement('div');
  el.className = `ntf ${cls}`;
  el.textContent = msg;
  c.appendChild(el);
  setTimeout(()=>el.remove(), 4500);
}

function closeAlert() { document.getElementById('alert').classList.remove('show'); }
function showAlert(msg) {
  document.getElementById('alert-txt').textContent = msg;
  document.getElementById('alert').classList.add('show');
  setTimeout(closeAlert, 8000);
}

/* ═══════════════════════════════════════════════════════════
   CLOCK
   ═══════════════════════════════════════════════════════════ */
function updateClock() {
  const n = new Date();
  document.getElementById('tclock').textContent = n.toLocaleTimeString('zh-CN',{hour12:false}) + ' CST';
}

/* ═══════════════════════════════════════════════════════════
   TICKER
   ═══════════════════════════════════════════════════════════ */
function updateTicker(newsItems, ghRepos) {
  const parts = [];
  if(ghRepos?.length) {
    const top = ghRepos.slice(0,3);
    top.forEach(r => parts.push(`🔥 ${r.full_name} ⭐${fmtNum(r.stargazers_count)}`));
  }
  if(newsItems?.length) {
    newsItems.slice(0,4).forEach(n => parts.push(`📰 ${stripHtml(n.title||'').slice(0,40)}`));
  }
  parts.push('💼 点击「招聘」查看教育行业实时职位', '📡 点击「直播」跳转各平台直播间', '🎯 点击「关键词」查看趋势数据');
  document.getElementById('tkinner').textContent = parts.join('    |    ') + '          ';
}

