<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduMonitor · 教育行业实时情报台 v3</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=JetBrains+Mono:wght@300;400;500&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ═══ DESIGN TOKENS ════════════════════════════════════════════ */
:root{
  --bg0:#040810;--bg1:#070d1a;--bg2:#0c1426;--bg3:#111c34;
  --panel:rgba(7,13,26,.96);
  --blue:#3b82f6;--cyan:#06b6d4;--green:#10b981;--red:#f43f5e;
  --amber:#f59e0b;--purple:#8b5cf6;--orange:#fb923c;
  --b:rgba(59,130,246,.13);--bh:rgba(59,130,246,.35);
  --t0:#edf4ff;--t1:#8ca0be;--t2:#3c4f6a;
  --fh:'Rajdhani',sans-serif;--fm:'JetBrains Mono',monospace;--fcn:'Noto Sans SC',sans-serif;
  --nav:52px;--top:46px;--bot:24px;--drawer:460px;--r:5px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;font-size:12px;font-family:var(--fcn);color:var(--t0);background:var(--bg0)}
body{background-image:radial-gradient(ellipse 70% 40% at 50% 0%,rgba(59,130,246,.04) 0%,transparent 60%)}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:rgba(59,130,246,.3);border-radius:2px}

/* ═══ TOPBAR ════════════════════════════════════════════════════ */
#topbar{
  position:fixed;top:0;left:0;right:0;z-index:300;height:var(--top);
  background:rgba(4,8,16,.97);border-bottom:1px solid var(--b);
  display:flex;align-items:center;padding:0 14px;gap:12px;
  backdrop-filter:blur(20px);
}
.tlogo{font-family:var(--fh);font-size:18px;font-weight:700;letter-spacing:2.5px;color:var(--blue);text-transform:uppercase;display:flex;align-items:center;gap:8px}
.tlogo em{color:var(--t0);font-style:normal}
.pdot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pd 2s infinite}
@keyframes pd{0%,100%{transform:scale(1)}50%{transform:scale(1.5);opacity:.5}}
.tsep{width:1px;height:20px;background:var(--b)}
.tstat{display:flex;align-items:center;gap:5px;font-family:var(--fm);font-size:10.5px;color:var(--t1);white-space:nowrap}
.tv{color:var(--t0);font-weight:500}.tvg{color:var(--green)}.tvr{color:var(--red)}.tva{color:var(--amber)}
.tright{margin-left:auto;display:flex;align-items:center;gap:9px}
.chip{padding:2px 7px;border-radius:3px;font-family:var(--fm);font-size:9px;font-weight:600;letter-spacing:1px;border:1px solid}
.chip-live{border-color:rgba(244,63,94,.4);color:var(--red);background:rgba(244,63,94,.08);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.6}}
.chip-v3{border-color:rgba(59,130,246,.3);color:var(--blue);background:rgba(59,130,246,.07)}
#tclock{font-family:var(--fm);font-size:11px;color:var(--t1)}

/* ═══ ALERT BANNER ═══════════════════════════════════════════════ */
#alert{
  position:fixed;top:var(--top);left:var(--nav);right:0;z-index:280;
  background:rgba(245,158,11,.1);border-bottom:1px solid rgba(245,158,11,.3);
  padding:5px 16px;display:none;align-items:center;gap:8px;
  font-size:10.5px;font-family:var(--fm);color:var(--amber);
}
#alert.show{display:flex;animation:sdown .25s ease}
@keyframes sdown{from{transform:translateY(-100%);opacity:0}to{transform:none;opacity:1}}

/* ═══ NAV SIDEBAR ════════════════════════════════════════════════ */
#nav{
  position:fixed;left:0;top:var(--top);bottom:var(--bot);z-index:290;
  width:var(--nav);background:rgba(4,8,16,.95);border-right:1px solid var(--b);
  display:flex;flex-direction:column;align-items:center;padding:10px 0;gap:3px;
  backdrop-filter:blur(10px);
}
.nb{
  width:40px;height:40px;border-radius:var(--r);display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:2px;cursor:pointer;
  border:1px solid transparent;transition:all .15s;font-size:15px;line-height:1;
  position:relative;
}
.nb:hover,.nb.active{background:rgba(59,130,246,.08);border-color:var(--bh)}
.nb-lbl{font-family:var(--fm);font-size:7.5px;color:var(--t2);transition:color .15s}
.nb.active .nb-lbl{color:var(--blue)}
.nb-tt{
  position:absolute;left:48px;top:50%;transform:translateY(-50%);
  background:var(--bg3);border:1px solid var(--bh);padding:4px 9px;border-radius:3px;
  font-size:10.5px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;
  font-family:var(--fcn);z-index:400;
}
.nb:hover .nb-tt{opacity:1}

/* ═══ MAIN LAYOUT ════════════════════════════════════════════════ */
#main{
  position:fixed;top:var(--top);left:var(--nav);right:0;
  bottom:var(--bot);overflow:hidden;
  display:grid;grid-template-columns:1fr;
}
.main-inner{
  display:grid;grid-template-columns:260px 1fr;
  height:100%;overflow:hidden;
}

/* ═══ LEFT PANEL ═════════════════════════════════════════════════ */
#lpanel{
  background:var(--bg1);border-right:1px solid var(--b);
  display:flex;flex-direction:column;overflow:hidden;
}
.lsection{border-bottom:1px solid var(--b);flex-shrink:0}
.lsec-hdr{
  display:flex;align-items:center;gap:7px;padding:8px 11px 7px;
  border-bottom:1px solid var(--b);background:rgba(7,13,26,.7);
  font-family:var(--fh);font-size:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;
}
.lsec-hdr-icon{font-size:13px}
.lsec-badge{
  margin-left:auto;padding:1px 6px;border-radius:3px;
  font-family:var(--fm);font-size:8.5px;font-weight:600;border:1px solid;
}
.bd-ok{border-color:rgba(16,185,129,.35);color:var(--green);background:rgba(16,185,129,.07)}
.bd-live{border-color:rgba(244,63,94,.4);color:var(--red);background:rgba(244,63,94,.08)}
.bd-ai{border-color:rgba(139,92,246,.35);color:var(--purple);background:rgba(139,92,246,.07)}
.bd-info{border-color:rgba(59,130,246,.35);color:var(--blue);background:rgba(59,130,246,.07)}
.lsec-body{padding:8px 10px;overflow-y:auto}

/* overview cells */
.ov-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--b)}
.ovcell{background:var(--bg1);padding:8px 10px;cursor:default;transition:background .15s}
.ovcell:hover{background:var(--bg2)}
.ovval{font-family:var(--fm);font-size:17px;font-weight:600;line-height:1}
.ovlbl{font-size:9.5px;color:var(--t2);margin-top:2px}
.ovdelta{font-family:var(--fm);font-size:9px;margin-top:3px}
.dup{color:var(--green)}.ddn{color:var(--red)}.dnu{color:var(--t2)}

/* platform link buttons */
.plt-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.plt-btn{
  display:flex;align-items:center;gap:7px;padding:7px 9px;
  background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);
  cursor:pointer;text-decoration:none;color:var(--t0);
  transition:all .15s;
}
.plt-btn:hover{background:var(--bg3);border-color:var(--bh);transform:translateY(-1px)}
.plt-ic{font-size:16px;flex-shrink:0}
.plt-info{min-width:0}
.plt-name{font-size:10.5px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.plt-sub{font-size:9px;color:var(--t2);white-space:nowrap}
.plt-arrow{margin-left:auto;color:var(--t2);font-size:10px;flex-shrink:0}

/* company job links */
.co-link{
  display:flex;align-items:center;gap:8px;padding:5px 8px;margin-bottom:3px;
  background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);
  cursor:pointer;text-decoration:none;color:var(--t0);transition:all .15s;
}
.co-link:hover{border-color:var(--bh);background:var(--bg3)}
.co-dot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0}
.co-name{font-size:11px;font-weight:500;flex:1}
.co-desc{font-size:9.5px;color:var(--t2)}
.co-ext{font-size:9.5px;color:var(--t2)}

/* live rows */
.live-row{
  display:flex;align-items:center;gap:7px;padding:6px 8px;margin-bottom:4px;
  background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);transition:all .15s;
}
.live-row:hover{border-color:var(--bh);background:var(--bg3)}
.ld{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.ld.live{background:var(--red);box-shadow:0 0 6px var(--red);animation:lp 1.4s infinite}
.ld.offline{background:var(--t2)}
@keyframes lp{0%,100%{transform:scale(1)}50%{transform:scale(1.6);opacity:.5}}
.live-brand-name{font-size:11px;font-weight:500;flex:1}
.live-plt-links{display:flex;gap:4px}
.live-plt-a{
  padding:1px 6px;border-radius:3px;font-family:var(--fm);font-size:8.5px;font-weight:600;
  text-decoration:none;transition:opacity .15s;
}
.live-plt-a:hover{opacity:.8}
.a-dy{background:#0a0a0a;color:#fe2c55}
.a-bl{background:rgba(0,161,214,.15);color:#00a1d6}
.a-wb{background:rgba(230,22,45,.15);color:#e6162d}
.a-xhs{background:rgba(254,45,84,.15);color:#fe2d54}
.a-wx{background:rgba(7,193,96,.15);color:#07c160}
.a-ks{background:rgba(255,106,0,.15);color:#ff6a00}

/* ═══ CENTER CONTENT ═════════════════════════════════════════════ */
#cpanel{display:flex;flex-direction:column;overflow:hidden;background:var(--bg0)}

/* view tabs */
#vtabs{
  display:flex;gap:1px;border-bottom:1px solid var(--b);
  background:rgba(4,8,16,.97);flex-shrink:0;
  backdrop-filter:blur(10px);
  padding:0 4px;
}
.vtab{
  padding:0 14px;height:36px;display:flex;align-items:center;gap:6px;
  font-family:var(--fm);font-size:10.5px;color:var(--t2);cursor:pointer;
  border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;
}
.vtab:hover{color:var(--t1)}
.vtab.active{color:var(--blue);border-bottom-color:var(--blue)}
.vtab-icon{font-size:13px}

/* content views */
.view{display:none;flex:1;overflow:hidden;flex-direction:column}
.view.active{display:flex}
.view-body{flex:1;overflow-y:auto;padding:10px 12px}

/* ── GITHUB VIEW ── */
.gh-controls{
  display:flex;align-items:center;gap:8px;padding:8px 12px;
  border-bottom:1px solid var(--b);flex-shrink:0;background:rgba(4,8,16,.5);flex-wrap:wrap;
}
.period-tabs{display:flex;gap:2px;background:var(--bg2);border-radius:4px;padding:2px}
.ptab{
  padding:4px 11px;border-radius:3px;font-family:var(--fm);font-size:9.5px;
  color:var(--t2);cursor:pointer;transition:all .13s;
}
.ptab.active{background:var(--bg3);color:var(--t0)}
.topic-pills{display:flex;gap:4px;flex-wrap:wrap}
.tpill{
  padding:3px 9px;border-radius:12px;font-size:9.5px;cursor:pointer;
  border:1px solid var(--b);color:var(--t1);transition:all .13s;
  font-family:var(--fcn);
}
.tpill.active{border-color:var(--blue);color:var(--blue);background:rgba(59,130,246,.08)}
.gh-count-info{margin-left:auto;font-family:var(--fm);font-size:9.5px;color:var(--t2)}

.gh-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:8px;align-content:start}
.gh-card{
  background:var(--bg2);border:1px solid var(--b);border-left:3px solid var(--b);
  border-radius:var(--r);padding:10px 11px;cursor:pointer;
  transition:all .15s;text-decoration:none;display:block;
}
.gh-card:hover{border-left-color:var(--blue);border-color:var(--bh);transform:translateY(-1px);background:var(--bg3)}
.gh-r1{display:flex;align-items:center;gap:7px;margin-bottom:5px}
.gh-name{font-family:var(--fm);font-size:10.5px;color:var(--blue);font-weight:500;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.gh-lang{font-family:var(--fm);font-size:8.5px;padding:1px 5px;border-radius:2px}
.py{background:rgba(53,114,165,.2);color:#4c8aba}
.ts{background:rgba(43,116,137,.2);color:#2b7489}
.js{background:rgba(241,224,90,.1);color:#c9b940}
.rs{background:rgba(222,165,132,.15);color:#ce8c67}
.go{background:rgba(0,173,216,.12);color:#00add8}
.xx{background:rgba(148,163,184,.1);color:var(--t1)}
.gh-desc{font-size:10px;color:var(--t1);line-height:1.5;margin-bottom:7px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.gh-meta{display:flex;gap:10px;font-family:var(--fm);font-size:9.5px;color:var(--t2)}
.gh-stars{color:var(--amber)}.gh-forks{color:var(--t2)}.gh-iss{color:var(--t2)}
.gh-topics{display:flex;gap:4px;flex-wrap:wrap;margin-top:5px}
.gh-topic{padding:1px 6px;border-radius:10px;font-size:8.5px;background:rgba(59,130,246,.08);color:var(--blue);font-family:var(--fm)}

.shimmer{background:linear-gradient(90deg,var(--bg2) 25%,var(--bg3) 50%,var(--bg2) 75%);background-size:200% 100%;animation:shim 1.5s infinite}
@keyframes shim{0%{background-position:200% 0}100%{background-position:-200% 0}}
.gh-skel{height:120px;border-radius:var(--r)}

/* ── NEWS VIEW ── */
.news-controls{
  display:flex;align-items:center;gap:8px;padding:7px 12px;
  border-bottom:1px solid var(--b);flex-shrink:0;background:rgba(4,8,16,.5);flex-wrap:wrap;
}
.src-pill{
  padding:3px 9px;border-radius:12px;font-size:9.5px;cursor:pointer;
  border:1px solid var(--b);color:var(--t1);transition:all .13s;
}
.src-pill.active{border-color:var(--cyan);color:var(--cyan);background:rgba(6,182,212,.08)}
.news-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:8px;align-content:start}
.news-card{
  background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);
  padding:10px 11px;cursor:pointer;transition:all .15s;text-decoration:none;display:block;
}
.news-card:hover{border-color:var(--bh);background:var(--bg3);transform:translateY(-1px)}
.nc-src{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.nc-src-name{font-family:var(--fm);font-size:9px;font-weight:600;padding:1px 5px;border-radius:3px}
.nc-date{font-family:var(--fm);font-size:9px;color:var(--t2);margin-left:auto}
.nc-title{font-size:11.5px;font-weight:500;line-height:1.4;margin-bottom:5px}
.nc-excerpt{font-size:10px;color:var(--t1);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.nc-footer{display:flex;align-items:center;gap:6px;margin-top:7px}
.nc-author{font-size:9.5px;color:var(--t2);flex:1}
.nc-readmore{font-family:var(--fm);font-size:9px;color:var(--blue);text-decoration:none}
.nc-readmore:hover{text-decoration:underline}

/* source badge colors */
.src-tc{background:rgba(244,63,94,.15);color:var(--red)}
.src-es{background:rgba(16,185,129,.15);color:var(--green)}
.src-hn{background:rgba(245,158,11,.15);color:var(--amber)}
.src-xw{background:rgba(59,130,246,.15);color:var(--blue)}
.src-36{background:rgba(139,92,246,.15);color:var(--purple)}
.src-hx{background:rgba(6,182,212,.15);color:var(--cyan)}
.src-el{background:rgba(251,146,60,.15);color:var(--orange)}
.src-un{background:rgba(16,185,129,.15);color:var(--green)}

/* ── KEYWORDS VIEW ── */
.kw-search-bar{
  display:flex;align-items:center;gap:8px;padding:8px 12px;
  border-bottom:1px solid var(--b);flex-shrink:0;
}
.kw-input{
  flex:1;background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);
  padding:6px 10px;font-family:var(--fcn);font-size:11px;color:var(--t0);outline:none;
  transition:border-color .15s;
}
.kw-input:focus{border-color:var(--bh)}
.kw-search-btn{
  padding:6px 14px;background:rgba(59,130,246,.15);border:1px solid var(--bh);
  border-radius:var(--r);font-family:var(--fm);font-size:10px;color:var(--blue);
  cursor:pointer;transition:all .15s;
}
.kw-search-btn:hover{background:rgba(59,130,246,.25)}
.kw-presets{display:flex;gap:5px;padding:7px 12px;flex-wrap:wrap;border-bottom:1px solid var(--b)}
.kw-preset{
  padding:4px 10px;border-radius:12px;font-size:10px;cursor:pointer;
  border:1px solid var(--b);color:var(--t1);transition:all .13s;
}
.kw-preset:hover{border-color:var(--bh);color:var(--t0)}
.kw-tools-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;padding:10px 12px;align-content:start}
.kw-tool-card{
  background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);
  padding:10px;cursor:pointer;text-decoration:none;display:block;transition:all .15s;
}
.kw-tool-card:hover{border-color:var(--bh);background:var(--bg3);transform:translateY(-1px)}
.kw-tc-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.kw-tc-icon{font-size:18px}
.kw-tc-name{font-size:11px;font-weight:500}
.kw-tc-desc{font-size:9.5px;color:var(--t1);line-height:1.5;margin-bottom:6px}
.kw-tc-tags{display:flex;gap:3px;flex-wrap:wrap}
.kw-tc-tag{padding:1px 5px;border-radius:2px;font-size:8.5px;font-family:var(--fm);background:rgba(59,130,246,.08);color:var(--blue)}
.kw-tc-arrow{font-size:9px;color:var(--t2);margin-top:4px;text-align:right}

/* ── LIVE VIEW ── */
.live-view-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;align-content:start}
.live-brand-card{
  background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);
  padding:12px;transition:all .15s;
}
.live-brand-card:hover{border-color:var(--bh)}
.lbc-hdr{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.lbc-logo{width:36px;height:36px;border-radius:var(--r);background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:18px;border:1px solid var(--b)}
.lbc-info{flex:1}
.lbc-name{font-size:12px;font-weight:500;margin-bottom:2px}
.lbc-desc{font-size:9.5px;color:var(--t2)}
.lbc-status{display:flex;align-items:center;gap:5px;font-family:var(--fm);font-size:9px;margin-bottom:8px}
.lbc-status .ld{width:6px;height:6px}
.lbc-plts{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px}
.lbc-plt-a{
  padding:5px 4px;border-radius:3px;text-align:center;text-decoration:none;
  font-family:var(--fm);font-size:9px;font-weight:600;transition:opacity .15s;
  display:flex;flex-direction:column;align-items:center;gap:2px;
}
.lbc-plt-a:hover{opacity:.8}
.lbc-plt-a span:first-child{font-size:13px}
.lbc-plt-a span:last-child{font-size:8.5px}

/* ═══ DETAIL DRAWER ══════════════════════════════════════════════ */
#drawer{
  position:fixed;right:-480px;top:var(--top);bottom:var(--bot);z-index:400;
  width:460px;background:var(--bg1);border-left:1px solid var(--b);
  display:flex;flex-direction:column;overflow:hidden;
  transition:right .3s cubic-bezier(.4,0,.2,1);
  backdrop-filter:blur(20px);
}
#drawer.open{right:0}
#drawer-close{
  position:absolute;top:10px;right:12px;
  width:28px;height:28px;border-radius:50%;
  background:rgba(59,130,246,.1);border:1px solid var(--b);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:14px;color:var(--t1);transition:all .15s;z-index:1;
}
#drawer-close:hover{background:rgba(59,130,246,.2);color:var(--t0)}
#drawer-content{flex:1;overflow-y:auto;padding:14px}
.dr-source{font-family:var(--fm);font-size:9px;color:var(--t2);letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px}
.dr-title{font-size:15px;font-weight:500;line-height:1.4;margin-bottom:10px}
.dr-meta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--b)}
