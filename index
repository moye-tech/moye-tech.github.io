.dr-btn-icon{font-size:15px}
.dr-stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.dr-stat{background:var(--bg2);border:1px solid var(--b);border-radius:var(--r);padding:8px 10px;text-align:center}
.dr-stat-val{font-family:var(--fm);font-size:16px;font-weight:600;color:var(--t0);line-height:1}
